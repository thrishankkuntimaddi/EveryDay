{
  "name": "everyday",
  "version": "2.0.0",
  "description": "EveryDay — Discipline. Progression. Execution. (Client-Server Architecture)",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "dev:server":  "npm run dev --prefix server",
    "dev:client":  "npm run dev --prefix client -- --force",
    "dev":         "concurrently --names \"server,client\" --prefix-colors \"cyan,magenta\" \"npm run dev:server\" \"npm run dev:client\"",
    "start":       "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "author": "Thrishank Kuntimaddi",
  "license": "MIT"
}
